{
  "name": "pembukuan-telegram-bot",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "ALLOWED_USER_IDS": "1105904688,6373275001,7427314023",
    "ADMIN_USER_ID": "1105904688",
    "DATABASE_URL": "sqlite+aiosqlite:///./data/bookkeeping.db",
    "APP_TIMEZONE": "Asia/Makassar",
    "CURRENCY": "IDR",
    "LOG_LEVEL": "INFO",
    "BACKUP_DIR": "./backups",
    "EXPORT_DIR": "./exports",
    "EXPORT_TTL_SECONDS": "3600",
    "REMINDER_HOUR": "21"
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -e '.[dev]' && mkdir -p data exports backups && alembic upgrade head",
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "secrets": {
    "TELEGRAM_BOT_TOKEN": {
      "description": "A new Telegram bot token from @BotFather. Never commit it to the repository.",
      "documentationUrl": "https://core.telegram.org/bots/tutorial#obtain-your-bot-token"
    }
  }
}
